pipeline {
    agent any

    stages {

        stage('Checkout Code') {
            steps {
                git 'https://github.com/kousiksvr-colud/jenkins-java-project.git'
            }
        }

        stage('Build Project') {
            steps {
                sh 'mvn clean package'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t kousik-1 .'
            }
        }

        stage('Stop Old Container') {
            steps {
                sh 'docker rm -f mycontainer1 || true'
            }
        }

        stage('Run Container') {
            steps {
                sh 'docker run -d -p 1111:8080 --name mycontainer1 kousik-1'
            }
        }

    }
}
